<!DOCTYPE html>
<html>
<head>
  <title><%= post.title %> - DevConnect</title>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { background:#0f0f23; color:white; font-family:Arial, sans-serif; }
    .container { max-width:750px; margin:40px auto; padding:40px;
                 background:#1a1a2e; border-radius:10px; }
    h1 { color:#e94560; margin-bottom:15px; line-height:1.4; }
    .meta { color:#888; margin-bottom:30px; padding-bottom:20px;
            border-bottom:1px solid #333; }
    .content { line-height:1.8; color:#ccc; white-space:pre-line; }
    .back-btn { display:inline-block; margin-top:30px; padding:10px 20px;
                background:#e94560; color:white; text-decoration:none;
                border-radius:5px; }
  </style>
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container">
    <h1><%= post.title %></h1>
    <div class="meta">
      ✍️ By <strong><%= post.author ? post.author.name : 'Unknown' %></strong> |
      📅 <%= new Date(post.createdAt).toLocaleDateString('en-IN', {
        year:'numeric', month:'long', day:'numeric'
      }) %>
    </div>
    <div class="content"><%= post.content %></div>
    <a href="/dashboard" class="back-btn">← Wapas Dashboard</a>
  </div>
</body>
</html>